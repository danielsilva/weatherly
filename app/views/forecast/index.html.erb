<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
      <div class="card shadow">
        <div class="card-body text-center p-5">
          <h1 class="display-4 mb-3">Weatherly</h1>
          <p class="text-muted mb-4">Enter a location to get the current weather and forecast</p>
          
          <div id="alert-container">
            <% if flash[:alert] %>
              <div class="alert alert-danger">
                <%= flash[:alert] %>
              </div>
            <% end %>
          </div>
          
          <%= form_with url: forecast_path, method: :get, local: false, data: { turbo_frame: "forecast_results" } do |form| %>
            <div class="mb-3">
              <%= form.text_field :location, 
                  placeholder: "Enter city, address, or zip code...", 
                  class: "form-control form-control-lg",
                  autofocus: true %>
            </div>
            
            <div class="d-grid">
              <%= form.submit "Get Weather", class: "btn btn-primary btn-lg" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
  
  <div class="row justify-content-center mt-4">
    <div class="col-md-10 col-lg-8">
      <turbo-frame id="forecast_results"></turbo-frame>
    </div>
  </div>
</div>